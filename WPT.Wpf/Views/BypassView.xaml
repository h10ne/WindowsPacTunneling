<UserControl x:Class="WPT.Wpf.Views.BypassView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             xmlns:ctrl="clr-namespace:WPT.Wpf.Controls"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">

            <StackPanel HorizontalAlignment="Stretch">

                <TextBlock Text="Разблокировка YouTube, Discord и Telegram" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />

                <CheckBox Content="YouTube и Discord" IsChecked="{Binding BypassEnableZapret}" Margin="0,0,0,8"

                          IsEnabled="{Binding IsBypassEditingEnabled}" />

                <CheckBox Content="Telegram" IsChecked="{Binding BypassEnableTelegram}" Margin="0,0,0,12"

                          IsEnabled="{Binding IsBypassEditingEnabled}" />



                <TextBlock Text="{Binding BypassStatus}" TextWrapping="Wrap" Style="{StaticResource CaptionText}" Margin="0,0,0,12" />



                <Border Style="{StaticResource InfoBar}" Margin="0,0,0,12"
                        Visibility="{Binding IsBypassInfoTextVisible, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="{Binding BypassInfoText}" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" />

                </Border>



                <Expander IsExpanded="False" Margin="0,0,0,0">

                    <Expander.Header>

                        <StackPanel>

                            <TextBlock Text="Расширенные настройки" FontWeight="SemiBold" />

                            <TextBlock Text="Порт Telegram-прокси и выбранная стратегия zapret" Style="{StaticResource CaptionText}" Margin="0,2,0,0" />

                        </StackPanel>

                    </Expander.Header>

                    <StackPanel Margin="0,8,0,0" MinWidth="440">

                        <TextBlock Text="Порт MTProto-прокси" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                        <TextBox Text="{Binding TgWsProxyPort, UpdateSourceTrigger=PropertyChanged}"

                                 Width="100" HorizontalAlignment="Left" Margin="0,0,0,12"

                                 IsEnabled="{Binding IsTgWsProxyPortEditingEnabled}"

                                 ctrl:HintProperties.Hint="1443" />



                        <TextBlock Text="Стратегия zapret" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                        <TextBlock Text="{Binding BypassStrategyDisplay}" TextWrapping="Wrap" Margin="0,0,0,4" />

                    </StackPanel>

                </Expander>

            </StackPanel>

        </ScrollViewer>



        <Border Grid.Row="1" Padding="0,12,0,0" Margin="0,8,0,0"

                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*" />

                    <ColumnDefinition Width="Auto" />

                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="{Binding BypassToggleLabel}" Command="{Binding ToggleBypassCommand}"

                        HorizontalAlignment="Left" MinWidth="220">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">

                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsBypassRunning}" Value="True">

                                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                </Button>

                <Button Grid.Column="1" Content="{Binding BypassProbeLabel}" Command="{Binding ProbeBypassStrategyCommand}"

                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" MinWidth="180" Margin="12,0,0,0" />

            </Grid>

        </Border>

    </Grid>

</UserControl>
