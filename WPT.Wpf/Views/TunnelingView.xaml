<UserControl x:Class="WPT.Wpf.Views.TunnelingView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:vm="clr-namespace:WPT.Wpf.ViewModels"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             xmlns:ctrl="clr-namespace:WPT.Wpf.Controls"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             VerticalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />

        <Style x:Key="CustomListItem" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">

            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Setter Property="Margin" Value="0,0,0,2" />

        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

            <StackPanel HorizontalAlignment="Stretch">



                <Border Style="{StaticResource Card}">

                    <StackPanel Style="{StaticResource CardContent}" MinWidth="440">

                        <CheckBox Content="Весь трафик через прокси"

                                  IsChecked="{Binding RouteAllTrafficThroughProxy}" />

                        <TextBlock Text="Все сайты будут направляться через прокси-сервер, списки сервисов не используются"

                                   Style="{StaticResource CaptionText}" Margin="24,4,0,0" />

                    </StackPanel>

                </Border>



                <Border Style="{StaticResource Card}">

                    <Grid Style="{StaticResource CardContent}" MinWidth="440">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" MinWidth="200" />

                            <ColumnDefinition Width="120" />

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto" />

                            <RowDefinition Height="Auto" />

                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Text="Прокси-сервер" Style="{StaticResource CaptionText}" />

                        <TextBlock Grid.Column="1" Text="Порт PAC" Style="{StaticResource CaptionText}" Margin="12,0,0,0" />

                        <ComboBox Grid.Row="1" Grid.Column="0" IsEditable="True" Margin="0,4,0,0"

                                  ItemsSource="{Binding ProxyHistory}" Text="{Binding ProxyAddress, UpdateSourceTrigger=PropertyChanged}"

                                  ctrl:HintProperties.Hint="127.0.0.1:10808" />

                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="12,4,0,0" IsEditable="True"

                                  ItemsSource="{Binding PacPortHistory}" Text="{Binding PacPort, UpdateSourceTrigger=PropertyChanged}"

                                  ctrl:HintProperties.Hint="1080" />

                    </Grid>

                </Border>



                <Border Style="{StaticResource DisabledHintBar}"

                        Visibility="{Binding RouteAllTrafficThroughProxy, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="Не используется — включён режим «Весь трафик через прокси»"

                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />

                </Border>



                <Border Opacity="{Binding IsTunnelingListsEnabled, Converter={StaticResource BoolToOpacity}}">

                    <Border.Style>

                        <Style TargetType="Border">

                            <Setter Property="BorderThickness" Value="0" />

                            <Setter Property="Padding" Value="0" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding RouteAllTrafficThroughProxy}" Value="True">

                                    <Setter Property="Background" Value="#18000000" />

                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />

                                    <Setter Property="BorderThickness" Value="1" />

                                    <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />

                                    <Setter Property="Padding" Value="12,10,12,2" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Border.Style>



                    <StackPanel IsEnabled="{Binding IsTunnelingListsEnabled}">



                <Border Style="{StaticResource Card}">

                    <StackPanel Style="{StaticResource CardContent}" MinWidth="440">

                        <TextBlock Text="Списки сервисов" Style="{StaticResource SectionTitle}" />

                        <ItemsControl ItemsSource="{Binding SelectedLists}" Margin="0,0,0,12" MinHeight="36">

                            <ItemsControl.ItemsPanel>

                                <ItemsPanelTemplate>

                                    <WrapPanel />

                                </ItemsPanelTemplate>

                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>

                                <DataTemplate DataType="{x:Type vm:ListChipItem}">

                                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="{StaticResource RadiusChip}" Margin="0,0,8,8">

                                        <Grid MinHeight="28">

                                            <Grid.ColumnDefinitions>

                                                <ColumnDefinition Width="Auto" />

                                                <ColumnDefinition Width="28" />

                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Margin="10,5,10,5" />

                                            <Button Grid.Column="1" Content="×" Style="{StaticResource ChipRemoveZone}"

                                                    Command="{Binding DataContext.RemoveListCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

                                                    CommandParameter="{Binding}" />

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                        <ComboBox ItemsSource="{Binding AvailableLists}" DisplayMemberPath="DisplayName"

                                  SelectedItem="{Binding SelectedListToAdd}"

                                  ctrl:HintProperties.Hint="— добавить список —" />

                    </StackPanel>

                </Border>



                <Expander IsExpanded="False" Margin="0,8,0,0">

                    <Expander.Header>

                        <StackPanel>

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="Свои домены" FontWeight="SemiBold" />

                                <TextBlock Text="{Binding CustomDomains.Count, StringFormat=' ({0})'}" Foreground="{StaticResource TextSecondaryBrush}" />

                            </StackPanel>

                            <TextBlock Text="Пользовательские домены, добавленные вручную" Style="{StaticResource CaptionText}" Margin="0,2,0,0" />

                        </StackPanel>

                    </Expander.Header>

                    <StackPanel Margin="0,8,0,0" MinWidth="440">

                        <ListBox ItemsSource="{Binding CustomDomains}" Margin="0,0,0,8" ItemContainerStyle="{StaticResource CustomListItem}">

                            <ListBox.ItemTemplate>

                                <DataTemplate>

                                    <Grid MinHeight="34">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="*" />

                                            <ColumnDefinition Width="36" />

                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="10,0,4,0" />

                                        <Button Grid.Column="1" Content="×" Style="{StaticResource ListItemRemoveZone}"

                                                Command="{Binding DataContext.RemoveDomainCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

                                                CommandParameter="{Binding}" />

                                    </Grid>

                                </DataTemplate>

                            </ListBox.ItemTemplate>

                        </ListBox>

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}"

                                     ctrl:HintProperties.Hint="example.com" />

                            <Button Grid.Column="1" Content="+" Width="40" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"

                                    Command="{Binding AddDomainCommand}" />

                        </Grid>

                    </StackPanel>

                </Expander>



                <Expander IsExpanded="False" Margin="0,8,0,0">

                    <Expander.Header>

                        <StackPanel>

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="Свои IP и подсети" FontWeight="SemiBold" />

                                <TextBlock Text="{Binding CustomIps.Count, StringFormat=' ({0})'}" Foreground="{StaticResource TextSecondaryBrush}" />

                            </StackPanel>

                            <TextBlock Text="Пользовательские IP-адреса и CIDR, добавленные вручную" Style="{StaticResource CaptionText}" Margin="0,2,0,0" />

                        </StackPanel>

                    </Expander.Header>

                    <StackPanel Margin="0,8,0,0" MinWidth="440">

                        <ListBox ItemsSource="{Binding CustomIps}" Margin="0,0,0,8" ItemContainerStyle="{StaticResource CustomListItem}">

                            <ListBox.ItemTemplate>

                                <DataTemplate>

                                    <Grid MinHeight="34">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="*" />

                                            <ColumnDefinition Width="36" />

                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="10,0,4,0" />

                                        <Button Grid.Column="1" Content="×" Style="{StaticResource ListItemRemoveZone}"

                                                Command="{Binding DataContext.RemoveIpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

                                                CommandParameter="{Binding}" />

                                    </Grid>

                                </DataTemplate>

                            </ListBox.ItemTemplate>

                        </ListBox>

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding NewIp, UpdateSourceTrigger=PropertyChanged}"

                                     ctrl:HintProperties.Hint="1.2.3.4 или 10.0.0.0/8" />

                            <Button Grid.Column="1" Content="+" Width="40" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"

                                    Command="{Binding AddIpCommand}" />

                        </Grid>

                    </StackPanel>

                </Expander>



                    </StackPanel>

                </Border>



            </StackPanel>

        </ScrollViewer>



        <Border Grid.Row="1" Padding="0,12,0,0" Margin="0,8,0,0"

                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

            <StackPanel Orientation="Horizontal">

                <Button Content="Применить" Style="{StaticResource PrimaryButton}" Command="{Binding ApplyCommand}" Margin="0,0,8,0" />

                <Button Content="Показать PAC" Style="{StaticResource SecondaryButton}" Command="{Binding ShowPacCommand}" Margin="0,0,8,0" />

                <Button Content="Отключить PAC" Style="{StaticResource DangerButton}" Command="{Binding DisablePacCommand}"

                        Visibility="{Binding IsPacActive, Converter={StaticResource BoolToVis}}" />

            </StackPanel>

        </Border>



    </Grid>

</UserControl>
