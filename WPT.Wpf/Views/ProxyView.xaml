<UserControl x:Class="WPT.Wpf.Views.ProxyView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:ctrl="clr-namespace:WPT.Wpf.Controls"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">

            <StackPanel HorizontalAlignment="Stretch">

                <TextBlock Text="Сохранённые конфигурации" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <ctrl:ProxyConfigSelector ItemsSource="{Binding SavedProxyConfigs}"

                                          SelectedItem="{Binding SelectedSavedProxyConfig}"

                                          DeleteCommand="{Binding DeleteSavedProxyConfigCommand}"

                                          IsEnabled="{Binding IsProxyEditingEnabled}"

                                          Margin="0,0,0,16" />



                <Expander IsExpanded="False"
                          Margin="0,0,0,16"
                          Expanded="OnAddConfigExpanderChanged"
                          Collapsed="OnAddConfigExpanderChanged">

                    <Expander.Header>

                        <StackPanel>

                            <TextBlock Text="Добавить конфигурацию" FontWeight="SemiBold" />

                            <TextBlock Text="Название и строка подключения vless, vmess, trojan или ss"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />

                        </StackPanel>

                    </Expander.Header>

                    <StackPanel Margin="0,8,0,0">

                        <TextBlock Text="Название конфигурации" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                        <TextBox Text="{Binding ProxyConfigName, UpdateSourceTrigger=PropertyChanged}"

                                 IsEnabled="{Binding IsProxyEditingEnabled}" Margin="0,0,0,12"

                                 ctrl:HintProperties.Hint="Мой сервер" />



                        <TextBlock Text="Строка подключения" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                        <TextBox Text="{Binding ProxyLink, UpdateSourceTrigger=PropertyChanged}"

                                 Style="{StaticResource MultilineTextBox}"

                                 Height="88" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"

                                 IsEnabled="{Binding IsProxyEditingEnabled}"

                                 ctrl:HintProperties.Hint="vless://uuid@server:443?security=reality&amp;type=tcp#remark" />



                        <Grid Margin="0,0,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Сохранить конфигурацию"
                                    Command="{Binding SaveProxyConfigCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="180" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProxyConfigSaveNotice}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="12"
                                       Visibility="{Binding HasProxyConfigSaveNotice, Converter={StaticResource BoolToVis}}" />

                        </Grid>

                    </StackPanel>

                </Expander>



                <TextBlock Text="Локальный порт" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <TextBox Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"

                         IsEnabled="{Binding IsProxyEditingEnabled}" Margin="0,0,0,8"

                         ctrl:HintProperties.Hint="10808" />



                <Border Style="{StaticResource InfoBar}">

                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"

                               Text="Локальный прокси не меняет системные настройки. Укажите 127.0.0.1:порт на вкладке «Тунелирование»" />

                </Border>



            </StackPanel>

        </ScrollViewer>



        <Border Grid.Row="1" Padding="0,12,0,0" Margin="0,8,0,0"

                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

            <Button Content="{Binding ProxyToggleLabel}" Command="{Binding ToggleProxyCommand}" HorizontalAlignment="Left" MinWidth="140">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">

                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsProxyRunning}" Value="True">

                                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                </Button>

        </Border>

    </Grid>

</UserControl>
