<Window x:Class="WPT.Wpf.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:views="clr-namespace:WPT.Wpf.Views"

        xmlns:conv="clr-namespace:WPT.Wpf.Converters"

        xmlns:core="clr-namespace:WPT.Core;assembly=WPT.Core"

        Title="{x:Static core:AppBranding.DisplayName}"

        Width="900" Height="620" MinWidth="820" MinHeight="560"

        WindowStartupLocation="CenterScreen"

        KeyboardNavigation.TabNavigation="Cycle">

    <Window.Resources>

        <conv:SectionToVisibilityConverter x:Key="SectionVis" />

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="200" MinWidth="180" />

            <ColumnDefinition Width="*" MinWidth="560" />

        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>

            <RowDefinition Height="*" MinHeight="460" />

            <RowDefinition Height="36" />

        </Grid.RowDefinitions>



        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="*" />

                    <RowDefinition Height="Auto" />

                </Grid.RowDefinitions>



                <StackPanel Grid.Row="0" Margin="0,16,0,0">

                    <TextBlock Text="{x:Static core:AppBranding.DisplayName}" FontWeight="SemiBold" FontSize="15" Margin="20,0,0,20" />

                    <RadioButton Content="Тунелирование" Style="{StaticResource NavButton}" GroupName="Nav"

                                 IsChecked="{Binding IsTunnelingPage, Mode=TwoWay}" />

                    <RadioButton Content="Прокси" Style="{StaticResource NavButton}" GroupName="Nav"

                                 IsChecked="{Binding IsProxyPage, Mode=TwoWay}" />

                    <RadioButton Content="Process Mode" Style="{StaticResource NavButton}" GroupName="Nav"

                                 IsChecked="{Binding IsProcessModePage, Mode=TwoWay}" />

                    <RadioButton Content="Zapret + TG" Style="{StaticResource NavButton}" GroupName="Nav"

                                 IsChecked="{Binding IsBypassPage, Mode=TwoWay}" />

                    <RadioButton Content="Настройки" Style="{StaticResource NavButton}" GroupName="Nav"

                                 IsChecked="{Binding IsSettingsPage, Mode=TwoWay}" />

                </StackPanel>



                <views:StatusIndicatorsView Grid.Row="1" DataContext="{Binding}" Margin="20,0,12,16" VerticalAlignment="Bottom" />

            </Grid>

        </Border>



        <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource BgBrush}" Padding="24,16,24,16">

            <Grid>

                <views:TunnelingView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"

                                     Visibility="{Binding SelectedSection, Converter={StaticResource SectionVis}, ConverterParameter=0}" />

                <views:ProxyView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"

                                 Visibility="{Binding SelectedSection, Converter={StaticResource SectionVis}, ConverterParameter=1}" />

                <views:ProcessModeView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"

                                       Visibility="{Binding SelectedSection, Converter={StaticResource SectionVis}, ConverterParameter=2}" />

                <views:BypassView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"

                                  Visibility="{Binding SelectedSection, Converter={StaticResource SectionVis}, ConverterParameter=3}" />

                <views:SettingsView DataContext="{Binding}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"

                                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionVis}, ConverterParameter=4}" />

            </Grid>

        </Border>



        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,0">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*" />

                    <ColumnDefinition Width="Auto" />

                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding FooterLog}" Style="{StaticResource CaptionText}" VerticalAlignment="Center"

                           TextTrimming="CharacterEllipsis" ToolTip="{Binding FooterLog}" />

                <TextBlock Grid.Column="1" Text="{Binding AppVersionLabel}" Style="{StaticResource CaptionText}"

                           VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,0,0" />

            </Grid>

        </Border>

    </Grid>

</Window>
