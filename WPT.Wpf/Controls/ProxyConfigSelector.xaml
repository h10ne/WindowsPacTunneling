<UserControl x:Class="WPT.Wpf.Controls.ProxyConfigSelector"

             x:Name="Root"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             MinHeight="36"

             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ProxyPingButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTip" Value="Замерить пинг" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <Viewbox Width="12"
                                     Height="12"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Viewbox.RenderTransform>
                                    <TranslateTransform X="-1" />
                                </Viewbox.RenderTransform>
                                <Canvas Width="16" Height="16">
                                    <Path Data="M10,2 L5,9 L8,9 L7,15 L13,8 L10,8 Z"
                                          Fill="{StaticResource TextPrimaryBrush}" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFE6A800" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProxyDeleteButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTip" Value="Удалить конфигурацию" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <Viewbox Width="12"
                                     Height="12"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M6,2 L10,2 L11,4 L14,4 L14,5 L13,14 L3,14 L2,5 L2,4 L5,4 Z"
                                          Fill="{StaticResource TextPrimaryBrush}" />
                                    <Rectangle Canvas.Left="5" Canvas.Top="6" Width="1" Height="7" Fill="{StaticResource TextPrimaryBrush}" />
                                    <Rectangle Canvas.Left="7.5" Canvas.Top="6" Width="1" Height="7" Fill="{StaticResource TextPrimaryBrush}" />
                                    <Rectangle Canvas.Left="10" Canvas.Top="6" Width="1" Height="7" Fill="{StaticResource TextPrimaryBrush}" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProxyDropDownArrowButton" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                SnapsToDevicePixels="True">
                            <Path Data="M 0,2 L 4,6 L 8,2 Z"
                                  Fill="{StaticResource TextSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Width="8"
                                  Height="6"
                                  Stretch="Uniform"
                                  Margin="0,0,8,0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ProxyConfigLabelTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Margin="0,0,8,0" />
                <Border Background="{Binding ProtocolBrush}"
                        CornerRadius="4"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Protocol}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ProxyConfigRowTemplate">
            <Grid MinHeight="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Margin="0,0,8,0" />

                <Border Grid.Column="1"
                        Background="{Binding ProtocolBrush}"
                        CornerRadius="4"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                    <TextBlock Text="{Binding Protocol}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <TextBlock Grid.Column="3"
                           Text="{Binding PingDisplay}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="8,0,4,0"
                           Visibility="{Binding HasPingDisplay, Converter={StaticResource BoolToVis}}" />

                <Button Grid.Column="4"
                        Style="{StaticResource ProxyPingButton}"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        PreviewMouseLeftButtonDown="OnPingButtonMouseDown" />

                <Button Grid.Column="5"
                        Style="{StaticResource ProxyDeleteButton}"
                        VerticalAlignment="Center"
                        PreviewMouseLeftButtonDown="OnDeleteButtonMouseDown" />
            </Grid>
        </DataTemplate>

        <Style x:Key="ProxyConfigListBoxItem" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ElevatedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="MainBorder"
                Background="{StaticResource InputBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}"
                MinHeight="36"
                SnapsToDevicePixels="True">
            <Grid Margin="4,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        MouseLeftButtonUp="OnOpenDropDownClick">
                    <ContentControl Content="{Binding SelectedItem, ElementName=Root}"
                                    ContentTemplate="{StaticResource ProxyConfigLabelTemplate}"
                                    VerticalAlignment="Center" />
                </Border>

                <TextBlock Grid.Column="1"
                           DataContext="{Binding SelectedItem, ElementName=Root}"
                           Text="{Binding PingDisplay}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="8,0,4,0"
                           Visibility="{Binding HasPingDisplay, Converter={StaticResource BoolToVis}}" />

                <Button Grid.Column="2"
                        Style="{StaticResource ProxyPingButton}"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        DataContext="{Binding SelectedItem, ElementName=Root}"
                        PreviewMouseLeftButtonDown="OnPingButtonMouseDown" />

                <Button Grid.Column="3"
                        Style="{StaticResource ProxyDropDownArrowButton}"
                        Click="OnOpenDropDownClick"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch" />
            </Grid>
        </Border>

        <Popup x:Name="DropDownPopup"
               PlacementTarget="{Binding ElementName=MainBorder}"
               Placement="Bottom"
               AllowsTransparency="True"
               PopupAnimation="None"
               StaysOpen="False">
            <Border MinWidth="{Binding ActualWidth, ElementName=MainBorder}"
                    MaxHeight="240"
                    Background="{StaticResource InputBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}"
                    Margin="0,4,0,0"
                    SnapsToDevicePixels="True">
                <ListBox x:Name="DropDownList"
                         ItemsSource="{Binding ItemsSource, ElementName=Root}"
                         SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                         ItemTemplate="{StaticResource ProxyConfigRowTemplate}"
                         ItemContainerStyle="{StaticResource ProxyConfigListBoxItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="OnDropDownSelectionChanged"
                         PreviewMouseLeftButtonDown="OnDropDownItemMouseDown">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Border>
        </Popup>
    </Grid>

</UserControl>
