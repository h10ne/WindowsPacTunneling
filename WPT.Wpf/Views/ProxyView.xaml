<UserControl x:Class="WPT.Wpf.Views.ProxyView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:ctrl="clr-namespace:WPT.Wpf.Controls"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">

            <StackPanel HorizontalAlignment="Stretch">

                <TextBlock Text="Сохранённые конфигурации" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <ctrl:ProxyConfigSelector ItemsSource="{Binding SavedProxyConfigs}"

                                          SelectedItem="{Binding SelectedSavedProxyConfig}"

                                          DeleteCommand="{Binding DeleteSavedProxyConfigCommand}"

                                          IsEnabled="{Binding IsProxyEditingEnabled}"

                                          Margin="0,0,0,16" />



                <Expander IsExpanded="False"
                          Margin="0,0,0,16"
                          Expanded="OnAddConfigExpanderChanged"
                          Collapsed="OnAddConfigExpanderChanged"
                          IsEnabled="{Binding IsProxyEditingEnabled}">

                    <Expander.Header>

                        <StackPanel>

                            <TextBlock Text="Добавить конфигурацию" FontWeight="SemiBold" />

                            <TextBlock Text="Прокси (vless, vmess, trojan, ss) или VPN AmneziaWG"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />

                        </StackPanel>

                    </Expander.Header>

                    <TabControl Style="{StaticResource SettingsTabControl}" Margin="0,8,0,0">

                    <TabItem Header="Proxy">

                        <StackPanel Margin="0,12,0,0">

                            <TextBlock Text="Название конфигурации" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                            <TextBox Text="{Binding ProxyConfigName, UpdateSourceTrigger=PropertyChanged}"

                                     Margin="0,0,0,12"

                                     ctrl:HintProperties.Hint="Мой сервер" />



                            <TextBlock Text="Строка подключения" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                            <TextBlock Text="vless, vmess, trojan или ss"

                                       Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                            <TextBox Text="{Binding ProxyLink, UpdateSourceTrigger=PropertyChanged}"

                                     Style="{StaticResource MultilineTextBox}"

                                     Height="88" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"

                                     ctrl:HintProperties.Hint="vless://uuid@server:443?security=reality&amp;type=tcp#remark" />



                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Сохранить конфигурацию"
                                        Command="{Binding SaveProxyConfigCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        MinWidth="180" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding ProxyConfigSaveNotice}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontSize="12"
                                           Visibility="{Binding HasProxyConfigSaveNotice, Converter={StaticResource BoolToVis}}" />

                            </Grid>

                        </StackPanel>

                    </TabItem>



                    <TabItem Header="VPN">

                        <StackPanel Margin="0,12,0,0">

                            <TextBlock Text="Название конфигурации" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                            <TextBox Text="{Binding VpnConfigName, UpdateSourceTrigger=PropertyChanged}"

                                     Margin="0,0,0,12"

                                     ctrl:HintProperties.Hint="Мой AWG" />



                            <TextBlock Text="Конфигурация AmneziaWG" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                            <Border x:Name="VpnConfigDropZone"

                                    AllowDrop="True"

                                    DragOver="OnVpnConfigDragOver"

                                    Drop="OnVpnConfigDrop"

                                    MouseLeftButtonUp="OnVpnConfigDropZoneClick"

                                    Background="{StaticResource InputBrush}"

                                    BorderBrush="{StaticResource BorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="6"

                                    Padding="8,6"

                                    Margin="0,0,0,12">

                                <Border.Style>

                                    <Style TargetType="Border">

                                        <Setter Property="Cursor" Value="Hand" />

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding IsProxyEditingEnabled}" Value="False">

                                                <Setter Property="Cursor" Value="Arrow" />

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>

                                </Border.Style>

                                <Grid VerticalAlignment="Center">

                                    <TextBlock VerticalAlignment="Center"

                                               TextWrapping="Wrap"

                                               Foreground="{StaticResource TextSecondaryBrush}"

                                               Text="Перетащите сюда файл конфигурации (.conf) или нажмите для выбора"

                                               Visibility="{Binding IsVpnConfigDropHintVisible, Converter={StaticResource BoolToVis}}" />



                                    <StackPanel Visibility="{Binding HasPendingVpnConfig, Converter={StaticResource BoolToVis}}">

                                        <TextBlock Text="{Binding VpnConfigEndpoint, Mode=OneWay}"

                                                   FontWeight="SemiBold"

                                                   Foreground="{StaticResource TextPrimaryBrush}"

                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Text="{Binding VpnConfigSourceName, Mode=OneWay}"

                                                   Style="{StaticResource CaptionText}"

                                                   Margin="0,2,0,0"

                                                   TextTrimming="CharacterEllipsis" />

                                    </StackPanel>

                                </Grid>

                            </Border>



                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Применить конфигурацию"
                                        Command="{Binding SaveVpnConfigCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        MinWidth="180" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding VpnConfigSaveNotice}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontSize="12"
                                           Visibility="{Binding HasVpnConfigSaveNotice, Converter={StaticResource BoolToVis}}" />

                            </Grid>

                        </StackPanel>

                    </TabItem>

                </TabControl>

                </Expander>



                <TextBlock Text="Локальный порт" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <TextBox Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"

                         IsEnabled="{Binding IsProxyEditingEnabled}" Margin="0,0,0,8"

                         ctrl:HintProperties.Hint="10808" />



                <Border Style="{StaticResource InfoBar}">

                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"

                               Text="Локальный прокси не меняет системные настройки. Укажите 127.0.0.1:порт на вкладке «Тунелирование»" />

                </Border>



            </StackPanel>

        </ScrollViewer>



        <Border Grid.Row="1" Padding="0,12,0,0" Margin="0,8,0,0"

                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

            <Button Content="{Binding ProxyToggleLabel}" Command="{Binding ToggleProxyCommand}" HorizontalAlignment="Left" MinWidth="140">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">

                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsProxyRunning}" Value="True">

                                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                </Button>

        </Border>

    </Grid>

</UserControl>
