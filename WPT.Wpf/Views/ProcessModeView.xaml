<UserControl x:Class="WPT.Wpf.Views.ProcessModeView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:ctrl="clr-namespace:WPT.Wpf.Controls"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ProcessListItem" TargetType="ListBoxItem">

            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Setter Property="Margin" Value="0,0,0,2" />

            <Setter Property="FocusVisualStyle" Value="{x:Null}" />

            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="ListBoxItem">

                        <Border Background="Transparent" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">

                            <ContentPresenter />

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="ProcessModeAppInput" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">

            <Style.Triggers>

                <DataTrigger Binding="{Binding IsProcessModeRunning}" Value="True">

                    <Setter Property="IsReadOnly" Value="True" />

                    <Setter Property="Focusable" Value="False" />

                    <Setter Property="IsTabStop" Value="False" />

                    <Setter Property="Background" Value="{StaticResource ButtonDisabledBackgroundBrush}" />

                    <Setter Property="Foreground" Value="{StaticResource ButtonDisabledForegroundBrush}" />

                    <Setter Property="BorderBrush" Value="{StaticResource ButtonDisabledBorderBrush}" />

                    <Setter Property="Cursor" Value="Arrow" />

                </DataTrigger>

            </Style.Triggers>

        </Style>

        <Style x:Key="ProcessModeAppsList" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">

            <Style.Triggers>

                <DataTrigger Binding="{Binding IsProcessModeRunning}" Value="True">

                    <Setter Property="Background" Value="{StaticResource ButtonDisabledBackgroundBrush}" />

                    <Setter Property="BorderBrush" Value="{StaticResource ButtonDisabledBorderBrush}" />

                </DataTrigger>

            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">

            <StackPanel HorizontalAlignment="Stretch">



                <TextBlock Text="Конфигурация VLESS" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <ctrl:ProxyConfigSelector ItemsSource="{Binding ProcessModeProxyConfigs}"

                                          SelectedItem="{Binding SelectedProcessModeProxyConfig}"

                                          DeleteCommand="{Binding DeleteSavedProxyConfigCommand}"

                                          IsEnabled="{Binding IsProcessModeEditingEnabled}"

                                          Margin="0,0,0,16" />



                <TextBlock Text="Локальный порт" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <TextBox Text="{Binding ProcessModePort, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"

                         IsEnabled="{Binding IsProcessModeEditingEnabled}" Margin="0,0,0,12"

                         ctrl:HintProperties.Hint="20808" />



                <Expander IsExpanded="True">

                    <Expander.Header>

                        <StackPanel>

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="Списки приложений" FontWeight="SemiBold" />

                                <TextBlock Text="{Binding ProcessModeApplications.Count, StringFormat=' ({0})'}"

                                           Foreground="{StaticResource TextSecondaryBrush}" />

                            </StackPanel>

                            <TextBlock Text="Имена процессов (.exe), трафик которых направляется через туннель"

                                       Style="{StaticResource CaptionText}" Margin="0,2,0,0" />

                        </StackPanel>

                    </Expander.Header>

                    <StackPanel Margin="0,8,0,0" MinWidth="440">

                        <ListBox ItemsSource="{Binding ProcessModeApplications}" Margin="0,0,0,8"

                                 Style="{StaticResource ProcessModeAppsList}"

                                 ItemContainerStyle="{StaticResource ProcessListItem}">

                            <ListBox.ItemTemplate>

                                <DataTemplate>

                                    <Grid MinHeight="34">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="*" />

                                            <ColumnDefinition Width="36" />

                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="10,0,4,0">

                                            <TextBlock.Style>

                                                <Style TargetType="TextBlock">

                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding DataContext.IsProcessModeRunning, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">

                                                            <Setter Property="Foreground" Value="{StaticResource ButtonDisabledForegroundBrush}" />

                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>

                                            </TextBlock.Style>

                                        </TextBlock>

                                        <Button Grid.Column="1" Content="×"

                                                Command="{Binding DataContext.RemoveProcessModeAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

                                                CommandParameter="{Binding}">

                                            <Button.Style>

                                                <Style TargetType="Button" BasedOn="{StaticResource ListItemRemoveZone}">

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding DataContext.IsProcessModeRunning, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">

                                                            <Setter Property="Visibility" Value="Collapsed" />

                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>

                                            </Button.Style>

                                        </Button>

                                    </Grid>

                                </DataTemplate>

                            </ListBox.ItemTemplate>

                        </ListBox>

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="Auto" />

                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding NewProcessModeApp, UpdateSourceTrigger=PropertyChanged}"

                                     Style="{StaticResource ProcessModeAppInput}"

                                     ctrl:HintProperties.Hint="Название процесса" />

                            <Button Grid.Column="1" Content="+" Margin="8,0,0,0" Style="{StaticResource CompactAddButton}"

                                    IsEnabled="{Binding IsProcessModeEditingEnabled}"

                                    Command="{Binding AddProcessModeAppCommand}" />

                            <Button Grid.Column="2" Content="Выбрать запущенный процесс" Margin="8,0,0,0"

                                    Style="{StaticResource SecondaryButton}"

                                    Visibility="Collapsed"

                                    Command="{Binding PickRunningProcessCommand}" />

                        </Grid>

                    </StackPanel>

                </Expander>



                <Border Style="{StaticResource InfoBar}" Margin="0,16,0,0"
                        Visibility="{Binding IsProcessModeInfoVisible, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="{Binding ProcessModeInfoText}" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" />

                </Border>



            </StackPanel>

        </ScrollViewer>



        <Border Grid.Row="1" Padding="0,12,0,0" Margin="0,8,0,0"

                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

            <StackPanel Orientation="Horizontal">

                <Button Content="Применить" Style="{StaticResource PrimaryButton}" Command="{Binding ApplyProcessModeCommand}" Margin="0,0,8,0" />

                <Button Content="{Binding ProcessModeToggleLabel}" Command="{Binding ToggleProcessModeCommand}" MinWidth="140">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">

                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsProcessModeRunning}" Value="True">

                                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                </Button>

            </StackPanel>

        </Border>



    </Grid>

</UserControl>
