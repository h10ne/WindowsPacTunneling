<UserControl x:Class="WPT.Wpf.Views.SettingsView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel HorizontalAlignment="Stretch">



            <TextBlock Text="Запуск" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" />

            <CheckBox Content="Запускать вместе со стартом системы" IsChecked="{Binding StartWithWindows}" />

            <CheckBox Content="Запускать прокси со стартом приложения" IsChecked="{Binding StartProxyWithApp}" />

            <CheckBox Content="Запускать свернутым в трей" IsChecked="{Binding StartMinimizedToTray}" />



            <TextBlock Text="Уведомления" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8" />

            <CheckBox Content="Уведомлять при сворачивании приложения" IsChecked="{Binding NotifyOnMinimizeToTray}" />



            <TextBlock Text="Данные" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8" />

            <CheckBox Content="Обновлять списки при запуске приложения" IsChecked="{Binding UpdateListsOnStartup}" Margin="0,0,0,16" />



            <Button Content="Обновить списки" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                    Command="{Binding UpdateListsCommand}" Margin="0,0,0,12" MinWidth="180" />



            <Button Content="Открыть папку данных" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                    Command="{Binding OpenDataFolderCommand}" Margin="0,0,0,12" MinWidth="180" />



            <Button Content="Сохранить настройки" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"

                    Command="{Binding SaveSettingsCommand}" MinWidth="180" />



        </StackPanel>

    </ScrollViewer>

</UserControl>
