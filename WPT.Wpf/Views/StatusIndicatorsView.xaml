<UserControl x:Class="WPT.Wpf.Views.StatusIndicatorsView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             HorizontalAlignment="Left"

             VerticalAlignment="Bottom">

    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

            <Ellipse Width="8" Height="8" VerticalAlignment="Center">

                <Ellipse.Style>

                    <Style TargetType="Ellipse">

                        <Setter Property="Fill" Value="#FF6B6B6E" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsProxyHealthy}" Value="True">

                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />

                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsProxyUnreachable}" Value="True">

                                <Setter Property="Fill" Value="{StaticResource DangerBrush}" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Ellipse.Style>

            </Ellipse>

            <TextBlock Text="{Binding FooterProxyStatus}" VerticalAlignment="Center" Style="{StaticResource CaptionText}"

                       Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />

        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

            <Ellipse Width="8" Height="8" VerticalAlignment="Center">

                <Ellipse.Style>

                    <Style TargetType="Ellipse">

                        <Setter Property="Fill" Value="#FF6B6B6E" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsBypassRunning}" Value="True">

                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Ellipse.Style>

            </Ellipse>

            <TextBlock Text="{Binding FooterBypassStatus}" VerticalAlignment="Center" Style="{StaticResource CaptionText}"

                       Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />

        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

            <Ellipse Width="8" Height="8" VerticalAlignment="Center">

                <Ellipse.Style>

                    <Style TargetType="Ellipse">

                        <Setter Property="Fill" Value="#FF6B6B6E" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsPacActive}" Value="True">

                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Ellipse.Style>

            </Ellipse>

            <TextBlock Text="{Binding FooterRight}" VerticalAlignment="Center" Style="{StaticResource CaptionText}"

                       Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />

        </StackPanel>

        <TextBlock Text="Доступны обновления" VerticalAlignment="Center" Margin="0,6,0,0"

                   TextTrimming="CharacterEllipsis">

            <TextBlock.Style>

                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">

                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />

                    <Setter Property="Cursor" Value="Hand" />

                    <Setter Property="Visibility" Value="Collapsed" />

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding IsAnyUpdateAvailable}" Value="True">

                            <Setter Property="Visibility" Value="Visible" />

                        </DataTrigger>

                    </Style.Triggers>

                </Style>

            </TextBlock.Style>

            <TextBlock.InputBindings>

                <MouseBinding Command="{Binding OpenSettingsForUpdateCommand}" MouseAction="LeftClick" />

            </TextBlock.InputBindings>

        </TextBlock>

    </StackPanel>

</UserControl>
