<UserControl x:Class="WPT.Wpf.Views.SettingsView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             VerticalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

    </UserControl.Resources>

    <TabControl Style="{StaticResource SettingsTabControl}"

                SelectedIndex="{Binding SettingsTabIndex, Mode=TwoWay}">

        <TabItem Header="Общие">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="*" />

                    <RowDefinition Height="Auto" />

                </Grid.RowDefinitions>



                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                    <StackPanel HorizontalAlignment="Stretch">



                        <TextBlock Text="Запуск" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" />

                        <CheckBox Content="Запускать вместе со стартом системы" IsChecked="{Binding StartWithWindows}" />

                        <CheckBox Content="Запускать от имени администратора" IsChecked="{Binding RunAsAdministrator}" />

                        <CheckBox Content="Запускать прокси со стартом приложения" IsChecked="{Binding StartProxyWithApp}" />

                        <CheckBox Content="Запускать Process Mode со стартом приложения" IsChecked="{Binding StartProcessModeWithApp}"

                                  IsEnabled="{Binding IsStartProcessModeWithAppEnabled}"

                                  Visibility="{Binding IsProcessModeUiVisible, Converter={StaticResource BoolToVis}}" />

                        <CheckBox Content="Запускать Zapret со стартом приложения" IsChecked="{Binding StartBypassWithApp}"

                                  IsEnabled="{Binding IsStartBypassWithAppEnabled}" />

                        <CheckBox Content="Запускать свернутым в трей" IsChecked="{Binding StartMinimizedToTray}" />

                        <CheckBox Content="Уведомлять при сворачивании приложения" IsChecked="{Binding NotifyOnMinimizeToTray}" />

                        <Button Content="Перезапустить от имени администратора" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding RestartAsAdminCommand}" Margin="0,12,0,0" MinWidth="280" />



                        <TextBlock Text="Вкладки" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8" />

                        <CheckBox Content="Показывать «Тунелирование»" IsChecked="{Binding ShowTunnelingTab}" />

                        <CheckBox Content="Показывать «Прокси»" IsChecked="{Binding ShowProxyTab}" />

                        <CheckBox Content="Показывать «Process Mode»" IsChecked="{Binding ShowProcessModeTab}"

                                  Visibility="{Binding IsProcessModeUiVisible, Converter={StaticResource BoolToVis}}" />

                        <CheckBox Content="Показывать «Zapret + TG»" IsChecked="{Binding ShowBypassTab}" />



                        <TextBlock Text="Тунелирование" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8" />

                        <CheckBox Content="Обновлять списки при запуске приложения" IsChecked="{Binding UpdateListsOnStartup}" />

                        <Button Content="Обновить списки" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding UpdateListsCommand}" Margin="0,12,0,0" MinWidth="180" />



                        <Button Content="Открыть папку данных" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding OpenDataFolderCommand}" Margin="0,24,0,0" MinWidth="180" />



                    </StackPanel>

                </ScrollViewer>



                <Border Grid.Row="1" Padding="0,12,0,0" Margin="0,8,0,0"

                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

                    <Button Content="Применить" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"

                            Command="{Binding SaveSettingsCommand}" Padding="16,10" />

                </Border>



            </Grid>

        </TabItem>



        <TabItem Header="Обновления">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                <StackPanel HorizontalAlignment="Stretch">



                    <TextBlock Text="Приложение" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" />

                    <TextBlock Text="{Binding AppUpdateStatus}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal">

                        <Button Content="Проверить наличие обновлений" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding CheckAppUpdateCommand}" MinWidth="220" />

                        <Button Content="Обновить" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding InstallAppUpdateCommand}" MinWidth="180" Margin="12,0,0,0" />

                    </StackPanel>



                    <TextBlock Text="Zapret" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8" />

                    <TextBlock Text="{Binding ZapretUpdateStatus}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal">

                        <Button Content="Проверить обновления" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding CheckZapretUpdateCommand}" MinWidth="180" />

                        <Button Content="Скачать обновление" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding DownloadZapretUpdateCommand}" MinWidth="180" Margin="12,0,0,0" />

                    </StackPanel>



                    <TextBlock Text="Sing-box" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8" />

                    <TextBlock Text="{Binding SingBoxUpdateStatus}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal">

                        <Button Content="Проверить обновления" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding CheckSingBoxUpdateCommand}" MinWidth="180" />

                        <Button Content="Скачать обновление" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding DownloadSingBoxUpdateCommand}" MinWidth="180" Margin="12,0,0,0" />

                    </StackPanel>



                    <TextBlock Text="Wireproxy (AmneziaWG)" Style="{StaticResource SectionTitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8" />

                    <TextBlock Text="{Binding AmneziaBoxUpdateStatus}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal">

                        <Button Content="Проверить обновления" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding CheckAmneziaBoxUpdateCommand}" MinWidth="180" />

                        <Button Content="Скачать обновление" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"

                                Command="{Binding DownloadAmneziaBoxUpdateCommand}" MinWidth="180" Margin="12,0,0,0" />

                    </StackPanel>



                </StackPanel>

            </ScrollViewer>

        </TabItem>

    </TabControl>

</UserControl>
