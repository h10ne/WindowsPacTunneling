<UserControl x:Class="WPT.Wpf.Views.ProcessModeView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:ctrl="clr-namespace:WPT.Wpf.Controls"

             xmlns:conv="clr-namespace:WPT.Wpf.Converters"

             MinWidth="480"

             HorizontalAlignment="Stretch"

             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ProcessListItem" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">

            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Setter Property="Margin" Value="0,0,0,2" />

        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">

            <StackPanel HorizontalAlignment="Stretch">



                <TextBlock Text="Тип подключения" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <ComboBox ItemsSource="{Binding ProcessModeConnectionTypes}"

                          DisplayMemberPath="DisplayName"

                          SelectedValuePath="Value"

                          SelectedValue="{Binding ProcessModeConnectionType}"

                          IsEnabled="{Binding IsProcessModeEditingEnabled}"

                          Margin="0,0,0,12" />



                <StackPanel Visibility="{Binding IsProcessModeLinkSelected, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="{Binding ProcessModeLinkCaption}" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                    <TextBox Text="{Binding ProcessModeLink, UpdateSourceTrigger=PropertyChanged}"

                             Style="{StaticResource MultilineTextBox}"

                             Height="72" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"

                             IsEnabled="{Binding IsProcessModeEditingEnabled}"

                             ctrl:HintProperties.Hint="{Binding ProcessModeLinkHint}" />

                </StackPanel>



                <StackPanel Visibility="{Binding IsProcessModeAmneziaSelected, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="Конфигурация Amnezia" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                    <Border x:Name="AmneziaConfigDropZone"

                            AllowDrop="True"

                            DragOver="OnAmneziaConfigDragOver"

                            Drop="OnAmneziaConfigDrop"

                            Background="{StaticResource InputBrush}"

                            BorderBrush="{StaticResource BorderBrush}"

                            BorderThickness="1"

                            CornerRadius="6"

                            Padding="10,8"

                            MinHeight="36"

                            Margin="0,0,0,12"

                            IsEnabled="{Binding IsProcessModeEditingEnabled}">

                        <Grid VerticalAlignment="Center">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="Auto" />

                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>



                            <TextBlock Grid.Column="0"

                                       VerticalAlignment="Center"

                                       Margin="0,0,8,0"

                                       TextTrimming="CharacterEllipsis"

                                       Foreground="{StaticResource TextSecondaryBrush}"

                                       Text="Перетащите .conf или нажмите «Выбрать файл»"

                                       Visibility="{Binding IsProcessModeAmneziaDropHintVisible, Converter={StaticResource BoolToVis}}" />



                            <TextBlock Grid.Column="0"

                                       VerticalAlignment="Center"

                                       Margin="0,0,8,0"

                                       TextTrimming="CharacterEllipsis"

                                       Visibility="{Binding HasProcessModeAmneziaConfig, Converter={StaticResource BoolToVis}}">

                                <Run Text="{Binding ProcessModeAmneziaEndpoint, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />

                                <Run Text=" · " Foreground="{StaticResource TextSecondaryBrush}" />

                                <Run Text="{Binding ProcessModeAmneziaSourceName, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" />

                            </TextBlock>



                            <Button Grid.Column="1"

                                    Content="Выбрать файл"

                                    Style="{StaticResource SecondaryButton}"

                                    Padding="10,6"

                                    MinHeight="32"

                                    Command="{Binding PickAmneziaConfigCommand}" />



                            <Button Grid.Column="2"

                                    Content="×"

                                    Width="32"

                                    MinHeight="32"

                                    Margin="6,0,0,0"

                                    Style="{StaticResource ListItemRemoveZone}"

                                    Command="{Binding ClearAmneziaConfigCommand}"

                                    ToolTip="Очистить"

                                    Visibility="{Binding HasProcessModeAmneziaConfig, Converter={StaticResource BoolToVis}}" />

                        </Grid>

                    </Border>

                </StackPanel>



                <TextBlock Text="Локальный порт" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />

                <TextBox Text="{Binding ProcessModePort, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"

                         IsEnabled="{Binding IsProcessModeEditingEnabled}" Margin="0,0,0,12"

                         ctrl:HintProperties.Hint="20808" />



                <Expander IsExpanded="True">

                    <Expander.Header>

                        <StackPanel>

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="Списки приложений" FontWeight="SemiBold" />

                                <TextBlock Text="{Binding ProcessModeApplications.Count, StringFormat=' ({0})'}"

                                           Foreground="{StaticResource TextSecondaryBrush}" />

                            </StackPanel>

                            <TextBlock Text="Имена процессов (.exe), трафик которых направляется через туннель"

                                       Style="{StaticResource CaptionText}" Margin="0,2,0,0" />

                        </StackPanel>

                    </Expander.Header>

                    <StackPanel Margin="0,8,0,0" MinWidth="440" IsEnabled="{Binding IsProcessModeEditingEnabled}">

                        <ListBox ItemsSource="{Binding ProcessModeApplications}" Margin="0,0,0,8" ItemContainerStyle="{StaticResource ProcessListItem}">

                            <ListBox.ItemTemplate>

                                <DataTemplate>

                                    <Grid MinHeight="34">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="*" />

                                            <ColumnDefinition Width="36" />

                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="10,0,4,0" />

                                        <Button Grid.Column="1" Content="×" Style="{StaticResource ListItemRemoveZone}"

                                                Command="{Binding DataContext.RemoveProcessModeAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"

                                                CommandParameter="{Binding}" />

                                    </Grid>

                                </DataTemplate>

                            </ListBox.ItemTemplate>

                        </ListBox>

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="Auto" />

                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding NewProcessModeApp, UpdateSourceTrigger=PropertyChanged}"

                                     ctrl:HintProperties.Hint="Discord или Update" />

                            <Button Grid.Column="1" Content="+" Width="40" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"

                                    Command="{Binding AddProcessModeAppCommand}" />

                            <Button Grid.Column="2" Content="Выбрать запущенный процесс" Margin="8,0,0,0"

                                    Style="{StaticResource SecondaryButton}"

                                    Command="{Binding PickRunningProcessCommand}" />

                        </Grid>

                    </StackPanel>

                </Expander>



                <Border Style="{StaticResource InfoBar}" Margin="0,16,0,0">

                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"

                               Text="Process Mode перехватывает TCP/UDP выбранных процессов через Redirector. Для Discord добавьте Discord и Update. PM использует отдельный sing-box 1.12 (sniff SNI). Требуются права администратора." />

                </Border>



                <StackPanel Orientation="Horizontal" Margin="0,16,0,12">

                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">

                        <Ellipse.Style>

                            <Style TargetType="Ellipse">

                                <Setter Property="Fill" Value="#FF6B6B6E" />

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsProcessModeRunning}" Value="True">

                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </Ellipse.Style>

                    </Ellipse>

                    <TextBlock Text="{Binding ProcessModeStatus}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />

                </StackPanel>



            </StackPanel>

        </ScrollViewer>



        <Border Grid.Row="1" Padding="0,12,0,0" Margin="0,8,0,0"

                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

            <StackPanel Orientation="Horizontal">

                <Button Content="Применить" Style="{StaticResource PrimaryButton}" Command="{Binding ApplyProcessModeCommand}" Margin="0,0,8,0" />

                <Button Content="{Binding ProcessModeToggleLabel}" Command="{Binding ToggleProcessModeCommand}" MinWidth="140">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">

                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsProcessModeRunning}" Value="True">

                                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                </Button>

            </StackPanel>

        </Border>



    </Grid>

</UserControl>
